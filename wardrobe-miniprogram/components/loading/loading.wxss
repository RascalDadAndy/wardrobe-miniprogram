/* components/loading/loading.wxss */

.loading-container {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: var(--spacing-lg);
}

.loading-container.fullscreen {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1000;
}

.loading-wrapper {
  display: flex;
  flex-direction: column;
  align-items: center;
}

/* 默认加载动画 */
.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  position: relative;
}

.spinner-circle {
  width: 100%;
  height: 100%;
  border: 6rpx solid var(--primary-light);
  border-top-color: var(--primary);
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}

/* 旋转环动画 */
.spinner-ring {
  width: 60rpx;
  height: 60rpx;
  position: relative;
}

.ring-segment {
  position: absolute;
  width: 100%;
  height: 100%;
  border-radius: 50%;
  border: 4rpx solid transparent;
  border-top-color: var(--primary);
  animation: spin 1s linear infinite;
}

.ring-segment:nth-child(1) {
  animation-delay: 0s;
}

.ring-segment:nth-child(2) {
  animation-delay: 0.1s;
  border-top-color: var(--primary-light);
}

.ring-segment:nth-child(3) {
  animation-delay: 0.2s;
  border-top-color: var(--accent);
}

.ring-segment:nth-child(4) {
  animation-delay: 0.3s;
  border-top-color: var(--primary-dark);
}

/* 点状加载动画 */
.dots-loader {
  display: flex;
  gap: 16rpx;
}

.dot {
  width: 20rpx;
  height: 20rpx;
  background: var(--primary);
  border-radius: 50%;
  animation: bounce 1.4s ease-in-out infinite both;
}

.dot:nth-child(1) {
  animation-delay: -0.32s;
}

.dot:nth-child(2) {
  animation-delay: -0.16s;
}

@keyframes bounce {
  0%, 80%, 100% {
    transform: scale(0);
  }
  40% {
    transform: scale(1);
  }
}

/* 加载文本 */
.loading-text {
  margin-top: var(--spacing-md);
  font-size: 26rpx;
  color: var(--text-secondary);
}
