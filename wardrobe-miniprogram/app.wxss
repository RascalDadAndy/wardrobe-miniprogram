/**app.wxss - 全局样式**/

/* ========== CSS变量定义 ========== */
page {
  --primary: #D4A574;
  --primary-dark: #B8935F;
  --primary-light: #E8D4C0;
  --accent: #E07B39;
  --background: #F5F0EB;
  --surface: #FFFFFF;
  --text: #333333;
  --text-secondary: #666666;
  --text-hint: #999999;
  --divider: #E0E0E0;
  --success: #4CAF50;
  --warning: #FFC107;
  --error: #F44336;
  
  --shadow-sm: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
  --shadow-md: 0 4rpx 16rpx rgba(0, 0, 0, 0.12);
  --shadow-lg: 0 8rpx 32rpx rgba(0, 0, 0, 0.16);
  
  --radius-sm: 8rpx;
  --radius-md: 16rpx;
  --radius-lg: 24rpx;
  --radius-xl: 32rpx;
  
  --spacing-xs: 8rpx;
  --spacing-sm: 16rpx;
  --spacing-md: 24rpx;
  --spacing-lg: 32rpx;
  --spacing-xl: 48rpx;
  
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', sans-serif;
  background-color: var(--background);
  color: var(--text);
  font-size: 28rpx;
  line-height: 1.6;
}

/* ========== 基础样式重置 ========== */
view, text, image, scroll-view, swiper, swiper-item, button, input, textarea {
  box-sizing: border-box;
  margin: 0;
  padding: 0;
}

/* ========== 容器样式 ========== */
.container {
  padding: var(--spacing-md);
  min-height: 100vh;
  background-color: var(--background);
}

.page-container {
  min-height: 100vh;
  background-color: var(--background);
  padding-bottom: calc(env(safe-area-inset-bottom) + 120rpx);
}

.card {
  background: var(--surface);
  border-radius: var(--radius-md);
  box-shadow: var(--shadow-sm);
  padding: var(--spacing-md);
  margin-bottom: var(--spacing-md);
}

/* ========== 文字样式 ========== */
.text-primary {
  color: var(--primary);
}

.text-accent {
  color: var(--accent);
}

.text-secondary {
  color: var(--text-secondary);
}

.text-hint {
  color: var(--text-hint);
}

.text-success {
  color: var(--success);
}

.text-warning {
  color: var(--warning);
}

.text-error {
  color: var(--error);
}

.text-center {
  text-align: center;
}

.text-right {
  text-align: right;
}

.text-bold {
  font-weight: bold;
}

.text-lg {
  font-size: 32rpx;
}

.text-xl {
  font-size: 36rpx;
}

.text-sm {
  font-size: 24rpx;
}

.text-xs {
  font-size: 20rpx;
}

/* ========== 布局样式 ========== */
.flex {
  display: flex;
}

.flex-column {
  display: flex;
  flex-direction: column;
}

.flex-wrap {
  flex-wrap: wrap;
}

.flex-center {
  display: flex;
  justify-content: center;
  align-items: center;
}

.flex-between {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.flex-around {
  display: flex;
  justify-content: space-around;
  align-items: center;
}

.flex-1 {
  flex: 1;
}

.align-center {
  align-items: center;
}

.justify-center {
  justify-content: center;
}

/* ========== 间距样式 ========== */
.mt-xs { margin-top: var(--spacing-xs); }
.mt-sm { margin-top: var(--spacing-sm); }
.mt-md { margin-top: var(--spacing-md); }
.mt-lg { margin-top: var(--spacing-lg); }
.mt-xl { margin-top: var(--spacing-xl); }

.mb-xs { margin-bottom: var(--spacing-xs); }
.mb-sm { margin-bottom: var(--spacing-sm); }
.mb-md { margin-bottom: var(--spacing-md); }
.mb-lg { margin-bottom: var(--spacing-lg); }
.mb-xl { margin-bottom: var(--spacing-xl); }

.ml-xs { margin-left: var(--spacing-xs); }
.ml-sm { margin-left: var(--spacing-sm); }
.ml-md { margin-left: var(--spacing-md); }
.ml-lg { margin-left: var(--spacing-lg); }

.mr-xs { margin-right: var(--spacing-xs); }
.mr-sm { margin-right: var(--spacing-sm); }
.mr-md { margin-right: var(--spacing-md); }
.mr-lg { margin-right: var(--spacing-lg); }

.p-xs { padding: var(--spacing-xs); }
.p-sm { padding: var(--spacing-sm); }
.p-md { padding: var(--spacing-md); }
.p-lg { padding: var(--spacing-lg); }

/* ========== 按钮样式 ========== */
.btn {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 88rpx;
  border-radius: var(--radius-md);
  font-size: 30rpx;
  font-weight: 500;
  transition: all 0.3s ease;
}

.btn-primary {
  background: linear-gradient(135deg, var(--primary) 0%, var(--primary-dark) 100%);
  color: #FFFFFF;
  box-shadow: var(--shadow-sm);
}

.btn-primary:active {
  opacity: 0.9;
  transform: scale(0.98);
}

.btn-accent {
  background: linear-gradient(135deg, var(--accent) 0%, #C96A2E 100%);
  color: #FFFFFF;
}

.btn-outline {
  background: transparent;
  border: 2rpx solid var(--primary);
  color: var(--primary);
}

.btn-outline:active {
  background: var(--primary-light);
}

.btn-disabled {
  background: var(--divider);
  color: var(--text-hint);
}

.btn-sm {
  height: 64rpx;
  font-size: 26rpx;
  padding: 0 var(--spacing-md);
}

/* ========== 表单样式 ========== */
.input {
  height: 88rpx;
  background: var(--surface);
  border: 2rpx solid var(--divider);
  border-radius: var(--radius-md);
  padding: 0 var(--spacing-md);
  font-size: 28rpx;
}

.input:focus {
  border-color: var(--primary);
}

/* ========== 图片样式 ========== */
.image-cover {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.image-contain {
  width: 100%;
  height: 100%;
  object-fit: contain;
}

/* ========== 分割线 ========== */
.divider {
  height: 2rpx;
  background: var(--divider);
  margin: var(--spacing-md) 0;
}

.divider-vertical {
  width: 2rpx;
  background: var(--divider);
  margin: 0 var(--spacing-md);
}

/* ========== 标签样式 ========== */
.tag {
  display: inline-flex;
  align-items: center;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
}

.tag-primary {
  background: var(--primary-light);
  color: var(--primary-dark);
}

.tag-accent {
  background: rgba(224, 123, 57, 0.15);
  color: var(--accent);
}

/* ========== 空状态 ========== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: var(--spacing-xl);
}

.empty-icon {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: var(--spacing-md);
  opacity: 0.5;
}

.empty-text {
  color: var(--text-hint);
  font-size: 28rpx;
}

/* ========== 加载状态 ========== */
.loading-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: var(--spacing-xl);
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid var(--primary-light);
  border-top-color: var(--primary);
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}

/* ========== 安全区域适配 ========== */
.safe-area-bottom {
  padding-bottom: constant(safe-area-inset-bottom);
  padding-bottom: env(safe-area-inset-bottom);
}

/* ========== 滚动优化 ========== */
scroll-view {
  -webkit-overflow-scrolling: touch;
}

/* ========== 隐藏滚动条 ========== */
::-webkit-scrollbar {
  display: none;
  width: 0;
  height: 0;
  background: transparent;
}

/* ========== 动画 ========== */
.fade-in {
  animation: fadeIn 0.3s ease;
}

@keyframes fadeIn {
  from {
    opacity: 0;
  }
  to {
    opacity: 1;
  }
}

.slide-up {
  animation: slideUp 0.3s ease;
}

@keyframes slideUp {
  from {
    transform: translateY(20rpx);
    opacity: 0;
  }
  to {
    transform: translateY(0);
    opacity: 1;
  }
}

/* ========== 悬浮按钮 ========== */
.fab {
  position: fixed;
  right: 40rpx;
  bottom: 160rpx;
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, var(--accent) 0%, #C96A2E 100%);
  box-shadow: var(--shadow-md);
  display: flex;
  justify-content: center;
  align-items: center;
  z-index: 100;
}

.fab:active {
  transform: scale(0.95);
}

/* ========== 网格布局 ========== */
.grid-2 {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: var(--spacing-md);
}

.grid-3 {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: var(--spacing-sm);
}
