/* 穿搭建议页面样式 - 智能穿搭助手 */

/* 页面容器 */
.container {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 40rpx;
}

/* 选择区域 */
.selection-section {
  padding: 30rpx;
}

.section-header {
  text-align: center;
  margin-bottom: 40rpx;
}

.header-title {
  display: block;
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 12rpx;
}

.header-desc {
  display: block;
  font-size: 26rpx;
  color: #888;
}

/* 选择组 */
.select-group {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
}

.group-title {
  display: flex;
  align-items: center;
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 24rpx;
}

.title-icon {
  font-size: 36rpx;
  margin-right: 12rpx;
}

/* 选项网格 */
.option-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20rpx;
}

.option-grid.season-grid {
  grid-template-columns: repeat(4, 1fr);
}

.option-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx 0;
  background: #f8f8f8;
  border-radius: 16rpx;
  border: 2rpx solid transparent;
  transition: all 0.3s ease;
}

.option-item.selected {
  background: #fff0f3;
  border-color: #FF6B9D;
}

.option-item.selected .option-name {
  color: #FF6B9D;
  font-weight: 500;
}

.option-icon {
  font-size: 48rpx;
  margin-bottom: 8rpx;
}

.option-name {
  font-size: 26rpx;
  color: #666;
}

/* 风格标签 */
.style-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.style-tag {
  padding: 16rpx 28rpx;
  background: #f8f8f8;
  border-radius: 32rpx;
  font-size: 26rpx;
  color: #666;
  transition: all 0.3s ease;
}

.style-tag.selected {
  background: linear-gradient(135deg, #FF6B9D 0%, #FF8E53 100%);
  color: #fff;
}

/* 操作区域 */
.action-section {
  padding: 20rpx 0;
}

.suggest-btn {
  width: 100%;
  height: 96rpx;
  background: linear-gradient(135deg, #FF6B9D 0%, #FF8E53 100%);
  color: #fff;
  font-size: 32rpx;
  font-weight: bold;
  border-radius: 48rpx;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s ease;
}

.suggest-btn.disabled {
  background: #ccc;
}

.suggest-btn:active:not(.disabled) {
  transform: scale(0.98);
  box-shadow: 0 8rpx 24rpx rgba(255, 107, 157, 0.4);
}

.loading {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.loading-spinner {
  width: 36rpx;
  height: 36rpx;
  border: 4rpx solid rgba(255, 255, 255, 0.3);
  border-top-color: #fff;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

/* 结果区域 */
.result-section {
  padding: 30rpx;
}

.result-header {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
}

.result-title {
  display: flex;
  align-items: center;
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 16rpx;
}

.result-params {
  display: flex;
  gap: 16rpx;
}

.param-tag {
  background: linear-gradient(135deg, #FF6B9D 0%, #FF8E53 100%);
  color: #fff;
  font-size: 24rpx;
  padding: 8rpx 20rpx;
  border-radius: 24rpx;
}

/* 推荐搭配 */
.outfit-recommend {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
}

.outfit-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

.outfit-image-container {
  position: relative;
  border-radius: 16rpx;
  overflow: hidden;
}

.outfit-image {
  width: 100%;
  height: 500rpx;
  display: block;
}

.outfit-score {
  position: absolute;
  top: 20rpx;
  right: 20rpx;
  background: linear-gradient(135deg, #FF6B9D 0%, #FF8E53 100%);
  border-radius: 50%;
  width: 100rpx;
  height: 100rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 16rpx rgba(255, 107, 157, 0.4);
}

.score-value {
  font-size: 40rpx;
  font-weight: bold;
  color: #fff;
}

.score-label {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.9);
}

/* 搭配详情 */
.outfit-details {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
}

.detail-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

.items-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.item-card {
  display: flex;
  align-items: center;
  background: #f8f8f8;
  border-radius: 16rpx;
  padding: 16rpx;
}

.item-image {
  width: 100rpx;
  height: 100rpx;
  border-radius: 12rpx;
  margin-right: 20rpx;
}

.item-info {
  flex: 1;
}

.item-name {
  display: block;
  font-size: 28rpx;
  color: #333;
  margin-bottom: 4rpx;
}

.item-category {
  display: block;
  font-size: 24rpx;
  color: #888;
}

.item-status {
  font-size: 22rpx;
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
}

.item-status.in {
  background: #e8f5e9;
  color: #4CAF50;
}

.item-status.out {
  background: #fff3e0;
  color: #FF9800;
}

/* AI点评 */
.ai-comment {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
}

.comment-title {
  display: flex;
  align-items: center;
  font-size: 30rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 20rpx;
}

.comment-content {
  background: rgba(255, 255, 255, 0.1);
  border-radius: 12rpx;
  padding: 24rpx;
}

.comment-text {
  font-size: 28rpx;
  color: #fff;
  line-height: 1.6;
}

/* 穿搭建议 */
.suggestion-tips {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
}

.tips-title {
  display: flex;
  align-items: center;
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

.tips-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.tip-item {
  display: flex;
  align-items: flex-start;
}

.tip-number {
  width: 40rpx;
  height: 40rpx;
  background: linear-gradient(135deg, #FF6B9D 0%, #FF8E53 100%);
  border-radius: 50%;
  color: #fff;
  font-size: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.tip-content {
  flex: 1;
  font-size: 26rpx;
  color: #666;
  line-height: 1.5;
}

/* 颜色分析 */
.color-analysis {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
}

.analysis-title {
  display: flex;
  align-items: center;
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

.color-palette {
  display: flex;
  gap: 20rpx;
  margin-bottom: 20rpx;
}

.color-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.color-block {
  width: 80rpx;
  height: 80rpx;
  border-radius: 16rpx;
  margin-bottom: 8rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
}

.color-name {
  font-size: 22rpx;
  color: #666;
}

.analysis-desc {
  font-size: 26rpx;
  color: #666;
  line-height: 1.5;
}

/* 适用场景 */
.applicable-scenes {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
}

.scenes-title {
  display: flex;
  align-items: center;
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

.scenes-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.scene-tag {
  background: #f0f0f0;
  color: #666;
  font-size: 24rpx;
  padding: 12rpx 24rpx;
  border-radius: 24rpx;
}

/* 结果操作按钮 */
.result-actions {
  display: flex;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.result-actions .action-btn {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx 0;
  border-radius: 16rpx;
  border: none;
  transition: all 0.3s ease;
}

.action-btn.tryon {
  background: #e3f2fd;
  color: #2196F3;
}

.action-btn.save {
  background: #e8f5e9;
  color: #4CAF50;
}

.action-btn.share {
  background: #fff3e0;
  color: #FF9800;
}

.action-btn:active {
  transform: scale(0.98);
}

.btn-icon {
  font-size: 40rpx;
  margin-bottom: 8rpx;
}

/* 重新获取 */
.retry-section {
  text-align: center;
  padding: 20rpx 0;
}

.retry-text {
  font-size: 28rpx;
  color: #FF6B9D;
  text-decoration: underline;
}

/* 历史建议 */
.history-section {
  padding: 30rpx;
}

.history-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.history-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
}

.clear-history {
  font-size: 26rpx;
  color: #999;
}

.history-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.history-item {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 16rpx;
  padding: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.history-image {
  width: 120rpx;
  height: 120rpx;
  border-radius: 12rpx;
  margin-right: 20rpx;
}

.history-info {
  flex: 1;
}

.history-occasion {
  display: block;
  font-size: 28rpx;
  color: #333;
  margin-bottom: 4rpx;
}

.history-date {
  display: block;
  font-size: 24rpx;
  color: #888;
}

.history-arrow {
  font-size: 32rpx;
  color: #ccc;
}

/* 底部占位 */
.bottom-space {
  height: 40rpx;
}
