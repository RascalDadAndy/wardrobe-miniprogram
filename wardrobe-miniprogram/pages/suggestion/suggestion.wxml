<!-- 穿搭建议页面 - 智能穿搭助手 -->
<view class="container">
  <!-- 选择区域 -->
  <view class="selection-section" wx:if="{{!showResult}}">
    <view class="section-header">
      <text class="header-title">获取AI穿搭建议</text>
      <text class="header-desc">选择场合和季节，AI为你推荐最佳穿搭</text>
    </view>
    
    <!-- 场合选择 -->
    <view class="select-group">
      <view class="group-title">
        <text class="title-icon">🎯</text>
        <text>选择场合</text>
      </view>
      <view class="option-grid">
        <view 
          class="option-item {{selectedOccasion === item.value ? 'selected' : ''}}" 
          wx:for="{{occasions}}" 
          wx:key="value"
          data-value="{{item.value}}"
          bindtap="selectOccasion"
        >
          <text class="option-icon">{{item.icon}}</text>
          <text class="option-name">{{item.name}}</text>
        </view>
      </view>
    </view>
    
    <!-- 季节选择 -->
    <view class="select-group">
      <view class="group-title">
        <text class="title-icon">🌤️</text>
        <text>选择季节</text>
      </view>
      <view class="option-grid season-grid">
        <view 
          class="option-item {{selectedSeason === item.value ? 'selected' : ''}}" 
          wx:for="{{seasons}}" 
          wx:key="value"
          data-value="{{item.value}}"
          bindtap="selectSeason"
        >
          <text class="option-icon">{{item.icon}}</text>
          <text class="option-name">{{item.name}}</text>
        </view>
      </view>
    </view>
    
    <!-- 风格偏好（可选） -->
    <view class="select-group">
      <view class="group-title">
        <text class="title-icon">✨</text>
        <text>风格偏好（可选）</text>
      </view>
      <view class="style-tags">
        <view 
          class="style-tag {{item.selected ? 'selected' : ''}}" 
          wx:for="{{stylePreferences}}" 
          wx:key="value"
          data-value="{{item.value}}"
          bindtap="toggleStyle"
        >
          {{item.name}}
        </view>
      </view>
    </view>
    
    <!-- 获取建议按钮 -->
    <view class="action-section">
      <button 
        class="suggest-btn {{canGetSuggestion ? '' : 'disabled'}}" 
        bindtap="getSuggestion"
        disabled="{{!canGetSuggestion || isLoading}}"
      >
        <text wx:if="{{!isLoading}}">获取穿搭建议</text>
        <view class="loading" wx:if="{{isLoading}}">
          <view class="loading-spinner"></view>
          <text>AI分析中...</text>
        </view>
      </button>
    </view>
  </view>

  <!-- 结果区域 -->
  <view class="result-section" wx:if="{{showResult}}">
    <!-- 结果头部 -->
    <view class="result-header">
      <view class="result-title">
        <text class="title-icon">✨</text>
        <text>AI穿搭建议</text>
      </view>
      <view class="result-params">
        <text class="param-tag">{{selectedOccasionName}}</text>
        <text class="param-tag">{{selectedSeasonName}}</text>
      </view>
    </view>
    
    <!-- 推荐搭配 -->
    <view class="outfit-recommend">
      <view class="outfit-title">推荐搭配</view>
      <view class="outfit-image-container">
        <image class="outfit-image" src="{{suggestion.outfitImage}}" mode="aspectFill" bindtap="previewOutfit"></image>
        <view class="outfit-score" wx:if="{{suggestion.score}}">
          <text class="score-value">{{suggestion.score}}</text>
          <text class="score-label">分</text>
        </view>
      </view>
    </view>
    
    <!-- 搭配详情 -->
    <view class="outfit-details">
      <view class="detail-title">搭配单品</view>
      <view class="items-list">
        <view class="item-card" wx:for="{{suggestion.items}}" wx:key="id">
          <image class="item-image" src="{{item.image}}" mode="aspectFill"></image>
          <view class="item-info">
            <text class="item-name">{{item.name}}</text>
            <text class="item-category">{{item.category}}</text>
          </view>
          <view class="item-status {{item.inWardrobe ? 'in' : 'out'}}">
            {{item.inWardrobe ? '已拥有' : '待添加'}}
          </view>
        </view>
      </view>
    </view>
    
    <!-- AI点评 -->
    <view class="ai-comment">
      <view class="comment-title">
        <text class="title-icon">💬</text>
        <text>AI点评</text>
      </view>
      <view class="comment-content">
        <text class="comment-text">{{suggestion.comment}}</text>
      </view>
    </view>
    
    <!-- 穿搭建议 -->
    <view class="suggestion-tips">
      <view class="tips-title">
        <text class="title-icon">💡</text>
        <text>穿搭建议</text>
      </view>
      <view class="tips-list">
        <view class="tip-item" wx:for="{{suggestion.tips}}" wx:key="index">
          <text class="tip-number">{{index + 1}}</text>
          <text class="tip-content">{{item}}</text>
        </view>
      </view>
    </view>
    
    <!-- 颜色搭配分析 -->
    <view class="color-analysis" wx:if="{{suggestion.colorAnalysis}}">
      <view class="analysis-title">
        <text class="title-icon">🎨</text>
        <text>色彩搭配分析</text>
      </view>
      <view class="color-palette">
        <view class="color-item" wx:for="{{suggestion.colorAnalysis.colors}}" wx:key="index">
          <view class="color-block" style="background-color: {{item.value}};"></view>
          <text class="color-name">{{item.name}}</text>
        </view>
      </view>
      <text class="analysis-desc">{{suggestion.colorAnalysis.description}}</text>
    </view>
    
    <!-- 适用场景 -->
    <view class="applicable-scenes">
      <view class="scenes-title">
        <text class="title-icon">📍</text>
        <text>适用场景</text>
      </view>
      <view class="scenes-list">
        <text class="scene-tag" wx:for="{{suggestion.scenes}}" wx:key="index">{{item}}</text>
      </view>
    </view>
    
    <!-- 操作按钮 -->
    <view class="result-actions">
      <button class="action-btn tryon" bindtap="tryOnOutfit">
        <text class="btn-icon">👔</text>
        <text>虚拟试穿</text>
      </button>
      <button class="action-btn save" bindtap="saveOutfit">
        <text class="btn-icon">💾</text>
        <text>保存搭配</text>
      </button>
      <button class="action-btn share" bindtap="shareOutfit">
        <text class="btn-icon">📤</text>
        <text>分享</text>
      </button>
    </view>
    
    <!-- 重新获取 -->
    <view class="retry-section">
      <text class="retry-text" bindtap="resetAndRetry">重新选择条件</text>
    </view>
  </view>

  <!-- 历史建议 -->
  <view class="history-section" wx:if="{{!showResult && suggestionHistory.length > 0}}">
    <view class="history-header">
      <text class="history-title">历史建议</text>
      <text class="clear-history" bindtap="clearHistory">清空</text>
    </view>
    <view class="history-list">
      <view class="history-item" wx:for="{{suggestionHistory}}" wx:key="id" bindtap="viewHistory" data-id="{{item.id}}">
        <image class="history-image" src="{{item.outfitImage}}" mode="aspectFill"></image>
        <view class="history-info">
          <text class="history-occasion">{{item.occasion}}</text>
          <text class="history-date">{{item.date}}</text>
        </view>
        <text class="history-arrow">></text>
      </view>
    </view>
  </view>

  <!-- 底部占位 -->
  <view class="bottom-space"></view>
</view>
