<!--pages/index/index.wxml - 首页-->
<view class="page-container">
  <!-- 未登录提示 -->
  <view class="login-tip" wx:if="{{!isLogin}}">
    <view class="login-content">
      <image class="login-icon" src="/images/icons/user.png" mode="aspectFit"/>
      <text class="login-text">登录后体验完整功能</text>
      <button class="btn btn-primary login-btn" bindtap="getUserProfile">立即登录</button>
    </view>
  </view>

  <!-- 欢迎区域 -->
  <view class="welcome-section" wx:if="{{isLogin && userInfo}}">
    <view class="welcome-content">
      <image class="avatar" src="{{userInfo.avatarUrl || '/images/default-avatar.png'}}" mode="aspectFill"/>
      <view class="welcome-text">
        <text class="greeting">{{'你好，' + (userInfo.nickName || '时尚达人')}}</text>
        <text class="subtitle">今天想穿什么风格？</text>
      </view>
    </view>
  </view>

  <!-- 轮播图 -->
  <view class="banner-section">
    <swiper class="banner-swiper" indicator-dots autoplay circular interval="3000">
      <swiper-item wx:for="{{bannerList}}" wx:key="id" bindtap="onBannerTap" data-index="{{index}}">
        <view class="banner-item">
          <image class="banner-image" src="{{item.image}}" mode="aspectFill"/>
          <view class="banner-title">{{item.title}}</view>
        </view>
      </swiper-item>
    </swiper>
  </view>

  <!-- 快捷操作 -->
  <view class="quick-actions card">
    <view class="section-title">快捷入口</view>
    <view class="actions-grid">
      <view class="action-item" 
            wx:for="{{quickActions}}" 
            wx:key="id"
            bindtap="onQuickActionTap"
            data-path="{{item.path}}">
        <view class="action-icon-wrapper">
          <image class="action-icon" src="{{item.icon}}" mode="aspectFit"/>
        </view>
        <text class="action-name">{{item.name}}</text>
      </view>
    </view>
  </view>

  <!-- 今日穿搭建议 -->
  <view class="suggestion-section card" wx:if="{{todaySuggestion}}">
    <view class="section-header">
      <view class="section-title">
        <text class="title-icon">✨</text>
        <text>今日穿搭推荐</text>
      </view>
      <view class="weather-info">
        <text class="temperature">{{todaySuggestion.temperature}}</text>
        <text class="weather">{{todaySuggestion.weather}}</text>
      </view>
    </view>
    <view class="suggestion-content">
      <view class="suggestion-title">{{todaySuggestion.title}}</view>
      <view class="suggestion-desc">{{todaySuggestion.description}}</view>
      <view class="suggestion-items">
        <view class="suggestion-item" wx:for="{{todaySuggestion.items}}" wx:key="type">
          <text class="item-type">{{item.type}}</text>
          <text class="item-name">{{item.name}}</text>
        </view>
      </view>
      <button class="btn btn-primary suggestion-btn" bindtap="onUseSuggestion">使用此搭配</button>
    </view>
  </view>

  <!-- 最近添加 -->
  <view class="recent-section card">
    <view class="section-header">
      <view class="section-title">
        <text class="title-icon">👕</text>
        <text>最近添加</text>
      </view>
      <view class="view-more" bindtap="onViewMore">
        <text>查看更多</text>
        <text class="arrow">></text>
      </view>
    </view>
    
    <view class="recent-grid" wx:if="{{recentClothes.length > 0}}">
      <view class="cloth-item" 
            wx:for="{{recentClothes}}" 
            wx:key="_id"
            bindtap="onClothTap"
            data-id="{{item._id}}">
        <image class="cloth-image" src="{{item.imageUrl}}" mode="aspectFill"/>
        <view class="cloth-info">
          <text class="cloth-name">{{item.name}}</text>
          <text class="cloth-category">{{item.category}}</text>
        </view>
      </view>
    </view>
    
    <view class="empty-state" wx:else>
      <image class="empty-icon" src="/images/empty-clothes.png" mode="aspectFit"/>
      <text class="empty-text">还没有添加衣物哦</text>
      <button class="btn btn-outline" bindtap="onQuickActionTap" data-path="/pages/upload/upload">去添加</button>
    </view>
  </view>

  <!-- 加载状态 -->
  <loading wx:if="{{isLoading}}" text="加载中..."/>
</view>
