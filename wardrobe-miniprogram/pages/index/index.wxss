/* pages/index/index.wxss - 首页样式 */

/* 登录提示 */
.login-tip {
  background: linear-gradient(135deg, var(--primary) 0%, var(--primary-dark) 100%);
  padding: 60rpx 40rpx;
  margin: var(--spacing-md);
  border-radius: var(--radius-lg);
}

.login-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  color: #FFFFFF;
}

.login-icon {
  width: 120rpx;
  height: 120rpx;
  margin-bottom: var(--spacing-md);
  opacity: 0.9;
}

.login-text {
  font-size: 32rpx;
  margin-bottom: var(--spacing-lg);
}

.login-btn {
  background: #FFFFFF !important;
  color: var(--primary) !important;
  min-width: 240rpx;
}

/* 欢迎区域 */
.welcome-section {
  background: linear-gradient(135deg, var(--primary) 0%, var(--primary-dark) 100%);
  padding: 40rpx;
  margin-bottom: var(--spacing-md);
}

.welcome-content {
  display: flex;
  align-items: center;
}

.avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255, 255, 255, 0.3);
  margin-right: var(--spacing-md);
}

.welcome-text {
  display: flex;
  flex-direction: column;
  color: #FFFFFF;
}

.greeting {
  font-size: 36rpx;
  font-weight: 600;
  margin-bottom: 8rpx;
}

.subtitle {
  font-size: 26rpx;
  opacity: 0.9;
}

/* 轮播图 */
.banner-section {
  margin: var(--spacing-md);
  border-radius: var(--radius-lg);
  overflow: hidden;
}

.banner-swiper {
  height: 320rpx;
  border-radius: var(--radius-lg);
}

.banner-item {
  position: relative;
  width: 100%;
  height: 100%;
}

.banner-image {
  width: 100%;
  height: 100%;
}

.banner-title {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 40rpx 30rpx 30rpx;
  background: linear-gradient(transparent, rgba(0, 0, 0, 0.6));
  color: #FFFFFF;
  font-size: 32rpx;
  font-weight: 500;
}

/* 快捷操作 */
.quick-actions {
  margin: var(--spacing-md);
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text);
  margin-bottom: var(--spacing-md);
  display: flex;
  align-items: center;
}

.title-icon {
  margin-right: 12rpx;
  font-size: 36rpx;
}

.actions-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: var(--spacing-md);
}

.action-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: var(--spacing-sm);
}

.action-icon-wrapper {
  width: 100rpx;
  height: 100rpx;
  border-radius: var(--radius-md);
  background: linear-gradient(135deg, var(--primary-light) 0%, #F5E6D3 100%);
  display: flex;
  justify-content: center;
  align-items: center;
  margin-bottom: var(--spacing-sm);
  transition: transform 0.2s;
}

.action-item:active .action-icon-wrapper {
  transform: scale(0.95);
}

.action-icon {
  width: 50rpx;
  height: 50rpx;
}

.action-name {
  font-size: 24rpx;
  color: var(--text);
}

/* 今日穿搭建议 */
.suggestion-section {
  margin: var(--spacing-md);
  background: linear-gradient(135deg, #FFF8F0 0%, #FFFFFF 100%);
  border: 2rpx solid var(--primary-light);
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: var(--spacing-md);
}

.weather-info {
  display: flex;
  align-items: center;
  background: var(--primary-light);
  padding: 8rpx 20rpx;
  border-radius: 30rpx;
}

.temperature {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--primary-dark);
  margin-right: 12rpx;
}

.weather {
  font-size: 24rpx;
  color: var(--text-secondary);
}

.suggestion-content {
  padding: var(--spacing-sm) 0;
}

.suggestion-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text);
  margin-bottom: var(--spacing-sm);
}

.suggestion-desc {
  font-size: 26rpx;
  color: var(--text-secondary);
  margin-bottom: var(--spacing-md);
}

.suggestion-items {
  display: flex;
  flex-wrap: wrap;
  gap: var(--spacing-sm);
  margin-bottom: var(--spacing-md);
}

.suggestion-item {
  display: flex;
  align-items: center;
  background: var(--background);
  padding: 12rpx 24rpx;
  border-radius: var(--radius-sm);
}

.item-type {
  font-size: 22rpx;
  color: var(--text-hint);
  margin-right: 12rpx;
}

.item-name {
  font-size: 26rpx;
  color: var(--text);
  font-weight: 500;
}

.suggestion-btn {
  width: 100%;
}

/* 最近添加 */
.recent-section {
  margin: var(--spacing-md);
}

.view-more {
  display: flex;
  align-items: center;
  color: var(--primary);
  font-size: 26rpx;
}

.arrow {
  margin-left: 8rpx;
}

.recent-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: var(--spacing-sm);
}

.cloth-item {
  position: relative;
  border-radius: var(--radius-md);
  overflow: hidden;
  background: var(--background);
}

.cloth-image {
  width: 100%;
  height: 200rpx;
  object-fit: cover;
}

.cloth-info {
  padding: var(--spacing-xs);
  background: var(--surface);
}

.cloth-name {
  display: block;
  font-size: 24rpx;
  color: var(--text);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.cloth-category {
  display: block;
  font-size: 20rpx;
  color: var(--text-hint);
  margin-top: 4rpx;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: var(--spacing-xl) var(--spacing-md);
}

.empty-icon {
  width: 160rpx;
  height: 160rpx;
  margin-bottom: var(--spacing-md);
  opacity: 0.5;
}

.empty-text {
  font-size: 28rpx;
  color: var(--text-hint);
  margin-bottom: var(--spacing-md);
}
