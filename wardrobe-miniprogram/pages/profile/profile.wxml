<!-- 个人中心页面 - 智能穿搭助手 -->
<view class="container">
  <!-- 用户信息卡片 -->
  <view class="user-card">
    <view class="user-bg"></view>
    <view class="user-info">
      <view class="avatar-section" bindtap="changeAvatar">
        <image class="user-avatar" src="{{userInfo.avatarUrl || '/images/default-avatar.png'}}" mode="aspectFill"></image>
        <view class="avatar-edit">
          <text class="edit-icon">📷</text>
        </view>
      </view>
      <view class="user-details">
        <text class="user-name">{{userInfo.nickName || '点击登录'}}</text>
        <text class="user-id" wx:if="{{userInfo.nickName}}">ID: {{userId}}</text>
        <view class="user-level" wx:if="{{userInfo.nickName}}">
          <text class="level-badge">{{level.name}}</text>
          <text class="level-progress">{{level.progress}}</text>
        </view>
      </view>
      <view class="login-btn" wx:if="{{!userInfo.nickName}}" bindtap="login">
        <text>立即登录</text>
      </view>
    </view>
  </view>

  <!-- 数据统计 -->
  <view class="stats-section">
    <view class="stats-grid">
      <view class="stats-item" bindtap="goToWardrobe">
        <text class="stats-number">{{stats.clothesCount}}</text>
        <text class="stats-label">衣物</text>
      </view>
      <view class="stats-item" bindtap="goToSavedOutfits">
        <text class="stats-number">{{stats.outfitCount}}</text>
        <text class="stats-label">搭配</text>
      </view>
      <view class="stats-item" bindtap="goToTryonHistory">
        <text class="stats-number">{{stats.tryonCount}}</text>
        <text class="stats-label">试衣</text>
      </view>
      <view class="stats-item">
        <text class="stats-number">{{stats.favoriteCount}}</text>
        <text class="stats-label">收藏</text>
      </view>
    </view>
  </view>

  <!-- 功能菜单 -->
  <view class="menu-section">
    <!-- 我的搭配 -->
    <view class="menu-group">
      <view class="menu-title">我的搭配</view>
      <view class="menu-list">
        <view class="menu-item" bindtap="goToSavedOutfits">
          <view class="item-left">
            <text class="item-icon">👗</text>
            <text class="item-name">保存的搭配</text>
          </view>
          <view class="item-right">
            <text class="item-count" wx:if="{{stats.outfitCount > 0}}">{{stats.outfitCount}}</text>
            <text class="item-arrow">></text>
          </view>
        </view>
        <view class="menu-item" bindtap="goToTryonHistory">
          <view class="item-left">
            <text class="item-icon">👔</text>
            <text class="item-name">试衣记录</text>
          </view>
          <view class="item-right">
            <text class="item-arrow">></text>
          </view>
        </view>
        <view class="menu-item" bindtap="goToFavorites">
          <view class="item-left">
            <text class="item-icon">❤️</text>
            <text class="item-name">我的收藏</text>
          </view>
          <view class="item-right">
            <text class="item-count" wx:if="{{stats.favoriteCount > 0}}">{{stats.favoriteCount}}</text>
            <text class="item-arrow">></text>
          </view>
        </view>
      </view>
    </view>

    <!-- 穿搭分析 -->
    <view class="menu-group">
      <view class="menu-title">穿搭分析</view>
      <view class="menu-list">
        <view class="menu-item" bindtap="goToWardrobeAnalysis">
          <view class="item-left">
            <text class="item-icon">📊</text>
            <text class="item-name">衣柜分析</text>
          </view>
          <view class="item-right">
            <text class="item-arrow">></text>
          </view>
        </view>
        <view class="menu-item" bindtap="goToStyleReport">
          <view class="item-left">
            <text class="item-icon">📈</text>
            <text class="item-name">风格报告</text>
          </view>
          <view class="item-right">
            <text class="item-arrow">></text>
          </view>
        </view>
        <view class="menu-item" bindtap="goToWearLog">
          <view class="item-left">
            <text class="item-icon">📝</text>
            <text class="item-name">穿搭日志</text>
          </view>
          <view class="item-right">
            <text class="item-arrow">></text>
          </view>
        </view>
      </view>
    </view>

    <!-- 设置 -->
    <view class="menu-group">
      <view class="menu-title">设置</view>
      <view class="menu-list">
        <view class="menu-item" bindtap="goToBodyInfo">
          <view class="item-left">
            <text class="item-icon">📏</text>
            <text class="item-name">身材信息</text>
          </view>
          <view class="item-right">
            <text class="item-arrow">></text>
          </view>
        </view>
        <view class="menu-item" bindtap="goToPreferences">
          <view class="item-left">
            <text class="item-icon">⚙️</text>
            <text class="item-name">偏好设置</text>
          </view>
          <view class="item-right">
            <text class="item-arrow">></text>
          </view>
        </view>
        <view class="menu-item" bindtap="goToNotifications">
          <view class="item-left">
            <text class="item-icon">🔔</text>
            <text class="item-name">消息通知</text>
          </view>
          <view class="item-right">
            <switch class="item-switch" checked="{{notificationEnabled}}" bindchange="toggleNotification"></switch>
          </view>
        </view>
        <view class="menu-item" bindtap="clearCache">
          <view class="item-left">
            <text class="item-icon">🗑️</text>
            <text class="item-name">清理缓存</text>
          </view>
          <view class="item-right">
            <text class="item-extra">{{cacheSize}}</text>
            <text class="item-arrow">></text>
          </view>
        </view>
      </view>
    </view>

    <!-- 帮助与反馈 -->
    <view class="menu-group">
      <view class="menu-title">帮助与反馈</view>
      <view class="menu-list">
        <view class="menu-item" bindtap="goToHelp">
          <view class="item-left">
            <text class="item-icon">❓</text>
            <text class="item-name">使用帮助</text>
          </view>
          <view class="item-right">
            <text class="item-arrow">></text>
          </view>
        </view>
        <view class="menu-item" bindtap="goToFeedback">
          <view class="item-left">
            <text class="item-icon">💬</text>
            <text class="item-name">意见反馈</text>
          </view>
          <view class="item-right">
            <text class="item-arrow">></text>
          </view>
        </view>
        <view class="menu-item" bindtap="goToAbout">
          <view class="item-left">
            <text class="item-icon">ℹ️</text>
            <text class="item-name">关于我们</text>
          </view>
          <view class="item-right">
            <text class="item-extra">v{{version}}</text>
            <text class="item-arrow">></text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- 退出登录 -->
  <view class="logout-section" wx:if="{{userInfo.nickName}}">
    <button class="logout-btn" bindtap="logout">退出登录</button>
  </view>

  <!-- 底部占位 -->
  <view class="bottom-space"></view>
</view>
