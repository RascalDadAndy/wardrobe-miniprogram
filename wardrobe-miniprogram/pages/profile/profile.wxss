/* 个人中心页面样式 - 智能穿搭助手 */

/* 页面容器 */
.container {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 40rpx;
}

/* 用户卡片 */
.user-card {
  position: relative;
  background: linear-gradient(135deg, #FF6B9D 0%, #FF8E53 100%);
  padding: 60rpx 40rpx 80rpx;
  overflow: hidden;
}

.user-bg {
  position: absolute;
  top: -50%;
  right: -20%;
  width: 400rpx;
  height: 400rpx;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 50%;
}

.user-info {
  position: relative;
  display: flex;
  align-items: center;
}

.avatar-section {
  position: relative;
  margin-right: 30rpx;
}

.user-avatar {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  border: 6rpx solid rgba(255, 255, 255, 0.3);
}

.avatar-edit {
  position: absolute;
  bottom: 0;
  right: 0;
  width: 44rpx;
  height: 44rpx;
  background: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.15);
}

.edit-icon {
  font-size: 24rpx;
}

.user-details {
  flex: 1;
}

.user-name {
  display: block;
  font-size: 40rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 8rpx;
}

.user-id {
  display: block;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-bottom: 12rpx;
}

.user-level {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.level-badge {
  background: rgba(255, 255, 255, 0.2);
  color: #fff;
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
}

.level-progress {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.8);
}

.login-btn {
  background: #fff;
  color: #FF6B9D;
  font-size: 28rpx;
  padding: 16rpx 40rpx;
  border-radius: 32rpx;
  font-weight: 500;
}

/* 数据统计 */
.stats-section {
  margin: -40rpx 30rpx 30rpx;
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.08);
  position: relative;
  z-index: 10;
}

.stats-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 20rpx;
}

.stats-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 0;
  transition: all 0.3s ease;
}

.stats-item:active {
  background: #f8f8f8;
  border-radius: 12rpx;
}

.stats-number {
  font-size: 44rpx;
  font-weight: bold;
  color: #FF6B9D;
  margin-bottom: 8rpx;
}

.stats-label {
  font-size: 24rpx;
  color: #888;
}

/* 菜单区域 */
.menu-section {
  padding: 0 30rpx;
}

.menu-group {
  margin-bottom: 30rpx;
}

.menu-title {
  font-size: 26rpx;
  color: #888;
  margin-bottom: 16rpx;
  padding-left: 10rpx;
}

.menu-list {
  background: #fff;
  border-radius: 20rpx;
  overflow: hidden;
}

.menu-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx 30rpx;
  border-bottom: 1rpx solid #f5f5f5;
  transition: background 0.3s ease;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-item:active {
  background: #f8f8f8;
}

.item-left {
  display: flex;
  align-items: center;
}

.item-icon {
  font-size: 36rpx;
  margin-right: 20rpx;
}

.item-name {
  font-size: 28rpx;
  color: #333;
}

.item-right {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.item-count {
  background: #ff4d4f;
  color: #fff;
  font-size: 20rpx;
  min-width: 32rpx;
  height: 32rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 8rpx;
}

.item-extra {
  font-size: 26rpx;
  color: #999;
}

.item-arrow {
  font-size: 28rpx;
  color: #ccc;
}

.item-switch {
  transform: scale(0.8);
}

/* 退出登录 */
.logout-section {
  padding: 30rpx;
}

.logout-btn {
  width: 100%;
  height: 88rpx;
  background: #fff;
  color: #ff4d4f;
  font-size: 30rpx;
  border-radius: 44rpx;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
}

.logout-btn:active {
  background: #fff1f0;
}

/* 底部占位 */
.bottom-space {
  height: 40rpx;
}
